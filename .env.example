T247_EMAIL=your@email.com
T247_PASSWORD=your_password
PORT=3847
T247_CONCURRENCY=3

# CPPP eProc (eprocure.gov.in) — optional second data source
# Portal uses CAPTCHA; set your scraper/API URL or use POST /api/cppp/ingest
# CPPP_DEBUG=1
# Delay between org fetches in ms (default 400)
# CPPP_FETCH_DELAY_MS=400
# Max orgs when using legacy top-N fetch (0 = all orgs on Fetch all)
# CPPP_MAX_ORGS=0
# CPPP_API_URL=https://your-scraper.example.com/tenders?page={page}
# CPPP_API_METHOD=GET
# CPPP_API_TOKEN=
# CPPP_API_HEADERS={"accept":"application/json"}
# CPPP_API_BODY={"page":1}
# CPPP_API_MAX_PAGES=20
# CPPP_DATA_FILE=./cppp_sample.json
